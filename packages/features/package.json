{
  "name": "@launchstack/features",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Launchstack vertical features on top of @launchstack/core. (Scaffolding stub — real sources land in later migration steps.)",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./adeu": {
      "types": "./src/adeu/index.ts",
      "default": "./src/adeu/index.ts"
    },
    "./legal-templates": {
      "types": "./src/legal-templates/index.ts",
      "default": "./src/legal-templates/index.ts"
    },
    "./voice": {
      "types": "./src/voice/index.ts",
      "default": "./src/voice/index.ts"
    },
    "./voice/whisper-js": {
      "types": "./src/voice/whisper-js.ts",
      "default": "./src/voice/whisper-js.ts"
    },
    "./repo-explainer": {
      "types": "./src/repo-explainer/index.ts",
      "default": "./src/repo-explainer/index.ts"
    },
    "./company-metadata": {
      "types": "./src/company-metadata/index.ts",
      "default": "./src/company-metadata/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@langchain/core": "^0.3.74",
    "@launchstack/core": "workspace:*",
    "docxtemplater": "^3.68.3",
    "drizzle-orm": "^0.45.1",
    "openai": "^4.62.1",
    "pizzip": "^3.2.0",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "sherpa-onnx-node": "^1.12.38"
  },
  "peerDependenciesMeta": {
    "sherpa-onnx-node": { "optional": true }
  },
  "devDependencies": {
    "sherpa-onnx-node": "^1.12.38"
  }
}
