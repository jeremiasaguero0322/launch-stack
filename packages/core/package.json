{
  "name": "@launchstack/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Launchstack engine: document ingestion, RAG, knowledge graph, OCR, LLM abstractions. Publishable once the full API surface lands (see plan).",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./db": {
      "types": "./src/db/index.ts",
      "default": "./src/db/index.ts"
    },
    "./db/schema": {
      "types": "./src/db/schema.ts",
      "default": "./src/db/schema.ts"
    },
    "./db/schema/*": {
      "types": "./src/db/schema/*.ts",
      "default": "./src/db/schema/*.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1"
  }
}
