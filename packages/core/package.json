{
  "name": "@launchstack/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Launchstack engine: document ingestion, RAG, knowledge graph, OCR, LLM abstractions. Publishable once the full API surface lands (see plan).",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./config": {
      "types": "./src/config/index.ts",
      "default": "./src/config/index.ts"
    },
    "./storage": {
      "types": "./src/storage/index.ts",
      "default": "./src/storage/index.ts"
    },
    "./db": {
      "types": "./src/db/index.ts",
      "default": "./src/db/index.ts"
    },
    "./db/schema": {
      "types": "./src/db/schema.ts",
      "default": "./src/db/schema.ts"
    },
    "./db/schema/*": {
      "types": "./src/db/schema/*.ts",
      "default": "./src/db/schema/*.ts"
    },
    "./guardrails": {
      "types": "./src/guardrails/index.ts",
      "default": "./src/guardrails/index.ts"
    },
    "./graph": {
      "types": "./src/graph/index.ts",
      "default": "./src/graph/index.ts"
    },
    "./ocr/types": {
      "types": "./src/ocr/types.ts",
      "default": "./src/ocr/types.ts"
    },
    "./ocr/complexity": {
      "types": "./src/ocr/complexity.ts",
      "default": "./src/ocr/complexity.ts"
    },
    "./ocr/code-chunker": {
      "types": "./src/ocr/code-chunker.ts",
      "default": "./src/ocr/code-chunker.ts"
    },
    "./ocr/chunker": {
      "types": "./src/ocr/chunker.ts",
      "default": "./src/ocr/chunker.ts"
    },
    "./ingestion": {
      "types": "./src/ingestion/index.ts",
      "default": "./src/ingestion/index.ts"
    },
    "./ingestion/types": {
      "types": "./src/ingestion/types.ts",
      "default": "./src/ingestion/types.ts"
    },
    "./ingestion/heading-chunker": {
      "types": "./src/ingestion/heading-chunker.ts",
      "default": "./src/ingestion/heading-chunker.ts"
    },
    "./providers": {
      "types": "./src/providers/index.ts",
      "default": "./src/providers/index.ts"
    },
    "./providers/registry": {
      "types": "./src/providers/registry.ts",
      "default": "./src/providers/registry.ts"
    },
    "./llm": {
      "types": "./src/llm/index.ts",
      "default": "./src/llm/index.ts"
    },
    "./llm/types": {
      "types": "./src/llm/types.ts",
      "default": "./src/llm/types.ts"
    },
    "./crypto": {
      "types": "./src/crypto/index.ts",
      "default": "./src/crypto/index.ts"
    },
    "./embeddings": {
      "types": "./src/embeddings/index.ts",
      "default": "./src/embeddings/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.3",
    "@langchain/core": "^0.3.74",
    "@langchain/google-genai": "^2.1.3",
    "@langchain/ollama": "^0.1.6",
    "@langchain/openai": "^0.6.11",
    "drizzle-orm": "^0.45.1",
    "openai": "^4.62.1",
    "postgres": "^3.4.7",
    "string-similarity-js": "^2.1.4"
  },
  "peerDependencies": {
    "neo4j-driver": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "neo4j-driver": { "optional": true }
  }
}
