{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js + Inngest (Full Dev)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "Next.js Only (Turbopack)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:next"],
      "port": 3000
    },
    {
      "name": "Inngest Dev Server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "inngest:dev"],
      "port": 8288
    },
    {
      "name": "Drizzle Studio (DB Browser)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "db:studio"],
      "port": 4983
    }
  ]
}
